# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# API_KEY: Clé API pour sécuriser les endpoints du serveur
API_KEY="your_api_key_here"

# ============================================
# CONFIGURATION BASE DE DONNÉES POSTGRESQL
# ============================================
# Pour Supabase: Utilisez les credentials de votre projet Supabase
# Pour PostgreSQL local: Utilisez vos credentials locaux

DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="kafarm_db"
DB_USER="postgres"
DB_PASSWORD="your_password_here"

# ============================================
# CONFIGURATION SUPABASE (Optionnel)
# ============================================
# Si vous utilisez Supabase, ajoutez ces variables:
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_SERVICE_KEY="your-service-key"
