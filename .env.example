# KA Farm - Configuration

# Base de données (PostgreSQL)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=kafarm

# Ou pour Supabase (recommandé pour commencer rapidement)
# PG_HOST=db.votre-projet.supabase.co
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=votre-mot-de-passe
# PG_DATABASE=postgres

# Firebase (optionnel si vous utilisez Firebase)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_DATABASE_ID=

# Firebase Admin SDK (REQUIS pour la production)
# Récupérer depuis Firebase Console > Project Settings > Service Accounts > Generate Private Key
# Coller le contenu JSON complet du fichier de service account en une seule ligne (remplacer les sauts de ligne par \n)
# Exemple: FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n..."}
FIREBASE_SERVICE_ACCOUNT_KEY=

# Gemini AI (requis pour le chatbot et Continue)
# Utilisez des clés distinctes pour Pro et Flash dans Continue
GEMINI_API_KEY=
GEMINI_PRO_KEY=
GEMINI_FLASH_KEY=

# ============================================
# SUPABASE CONFIGURATION (pour espace admin)
# ============================================
# Récupérer depuis Supabase > Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Application
NODE_ENV=development
PORT=3000
